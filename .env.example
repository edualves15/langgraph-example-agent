# ── LLM ───────────────────────────────────────────────────────────────────────
# Provider: google | openai | anthropic | ollama | <qualquer outro = custom>.
# O mapeamento provider→classe/modelo vive em app/services/llm_service.py (único ponto
# que lida com LLM); o modelo default por provider também é definido lá.
LLM_PROVIDER=google

# Chave do provider selecionado (GEMINI_API_KEY também é aceita, por compatibilidade).
LLM_API_KEY=change-me

# Base URL — usada pelo ollama e pelo provider custom (proxy OpenAI-compatível).
# Deixe vazia para os providers cloud (google/openai/anthropic).
LLM_BASE_URL=

# Camada de emulação de tool calling: ligue (true) para modelos SEM function calling
# nativo e/ou SEM streaming de tokens. Ver app/agent/tool_emulation.py.
LLM_TOOL_EMULATION=false

# ── AG-UI (protocolo/wire) ────────────────────────────────────────────────────
# Quando false, omite eventos RAW (passthrough de callbacks LangChain) do SSE,
# reduzindo o número de eventos no wire. Mantenha true para debugging.
AG_UI_STREAM_RAW_EVENTS=true

# ── Aplicação/servidor (prefixo APP_) ─────────────────────────────────────────
# CORS: origens permitidas (CSV). "*" libera todas (default). Com origens explícitas,
# os cookies/credenciais são habilitados automaticamente.
APP_CORS_ORIGINS=*

# Tamanho máximo do corpo de uma requisição, em bytes (proteção contra DoS). 0 desabilita.
APP_MAX_BODY_BYTES=2000000

# Timeout (s) por servidor MCP ao carregar tools no startup; o que estoura é logado e
# pulado. 0 desabilita.
APP_MCP_STARTUP_TIMEOUT=15

# Documentação OpenAPI (Swagger). true (default) expõe /docs, /redoc e /openapi.json.
# Em produção, recomenda-se false (reduz a superfície/exposição da API).
APP_ENABLE_DOCS=true
