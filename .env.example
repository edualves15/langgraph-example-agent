APP_ENV=local

# Gemini (obrigatório)
GEMINI_API_KEY=change-me
GEMINI_MODEL=gemini-3.1-flash-lite

# AG-UI: quando false, omite eventos RAW (passthrough de callbacks LangChain)
# no SSE, reduzindo significativamente o número de eventos no wire.
# Mantenha true se precisar dos callbacks internos para debugging.
AG_UI_STREAM_RAW_EVENTS=true

# CORS: origens permitidas (separadas por vírgula). "*" libera todas (default).
# Com origens explícitas, os cookies/credenciais são habilitados automaticamente.
AG_UI_CORS_ORIGINS=*

# Tamanho máximo do corpo de uma requisição, em bytes (proteção contra DoS).
# 0 desabilita o limite.
AG_UI_MAX_BODY_BYTES=2000000
